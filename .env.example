# ==============================================
# 🚀 Auto Investment Helper 환경 설정 
# ==============================================

# Backend 서버 설정
PORT=3001
FRONTEND_URL=http://localhost:3000

# 데이터베이스 (SQLite)
DATABASE_PATH=backend/data/investment.db

# ==============================================
# 🤖 AI 모델 설정 (필수)
# ==============================================

# Gemini API (주 모델 - 필수 설정)
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# OpenAI API (보조 모델 - 선택사항)
OPENAI_API_KEY=your_openai_api_key_here

# ==============================================
# ⏰ 스케줄링 옵션
# ==============================================

# 기본: 오전 8시, 오후 6시 리포트 생성
# 추가 옵션들 (true/false)
ENABLE_MIDDAY_REPORT=false          # 정오 12시 추가 리포트
ENABLE_WEEKLY_REPORT=false          # 주간 전망 리포트 (일요일 저녁)
ENABLE_PERIODIC_NEWS_COLLECTION=false  # 2시간마다 뉴스 수집

# 시장 데이터 수집 워커 (기본 비활성)
MARKET_DATA_INGESTION_ENABLED=false
MARKET_DATA_INGESTION_PROVIDER=stooq
MARKET_DATA_INGESTION_DATASET_ID=scheduled-daily-bars
MARKET_DATA_INGESTION_SYMBOLS=005930
MARKET_DATA_INGESTION_BENCHMARK=KOSPI200
MARKET_DATA_INGESTION_TIMEFRAME=1d
MARKET_DATA_INGESTION_CURRENCY=KRW
MARKET_DATA_INGESTION_LOOKBACK_DAYS=30
MARKET_DATA_HTTP_TIMEOUT_MS=10000
STOOQ_DAILY_CSV_BASE_URL=https://stooq.com/q/d/l/

# ==============================================
# 🔔 알림 설정 (선택사항)
# ==============================================

# 웹훅 URL (리포트 생성 완료 알림)
NOTIFICATION_WEBHOOK_URL=

# ==============================================
# 🛠️ 개발 설정
# ==============================================

# 로그 레벨 (debug, info, warn, error)
LOG_LEVEL=info

# Frontend API URL
REACT_APP_API_URL=http://localhost:3001
