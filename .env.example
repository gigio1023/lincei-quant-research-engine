# Copy to repo-root `.env` (gitignored). V1 CLI loads this via backend/src/shared/repo-env.loader.ts.
# Never commit `.env`.

# -----------------------------------------------------------------------------
# QuantConnect (LEAN CLI) — required for Docker backtests
# https://www.quantconnect.com/account → Security → User Id + API token
# -----------------------------------------------------------------------------
QUANTCONNECT_USER_ID=
QUANTCONNECT_API_TOKEN=

# -----------------------------------------------------------------------------
# OpenAI (V1 LLM alpha — run-alpha-cycle / meta committee)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
OPENAI_BASE_URL=https://api.openai.com/v1
REQUEST_TIMEOUT_S=30
COST_BUDGET_USD=5
MAX_PARALLEL=2

# -----------------------------------------------------------------------------
# Server / database (NestJS + SQLite)
# -----------------------------------------------------------------------------
PORT=3001
FRONTEND_URL=http://localhost:3000
DATABASE_PATH=backend/data/investment.db
TYPEORM_SYNCHRONIZE=true
TYPEORM_MIGRATIONS_RUN=false

# -----------------------------------------------------------------------------
# V1 pilot / LEAN
# -----------------------------------------------------------------------------
LEAN_CLI_PATH=
LEAN_ALLOW_SIMULATOR=false
LEAN_STRICT_CLI=true
ALLOW_SYNTHETIC_FEATURES=false
LIVE_PREFLIGHT_ALLOW_RESEARCH=false

STOOQ_API_KEY=
MARKET_DATA_INGESTION_ENABLED=false
MARKET_DATA_INGESTION_PROVIDER=stooq

# -----------------------------------------------------------------------------
# Live / broker (keep false until verified)
# -----------------------------------------------------------------------------
BROKER_WRITE_ENABLED=false
LIVE_TRADING_ENABLED=false
MAX_LIVE_PILOT_NOTIONAL_USD=10

LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Legacy report stack (optional)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
ENABLE_MIDDAY_REPORT=false
ENABLE_WEEKLY_REPORT=false
NOTIFICATION_WEBHOOK_URL=
