# Copy to repo-root `.env` (gitignored). V1 CLI loads this via backend/src/shared/repo-env.loader.ts.
# Never commit `.env`.

# -----------------------------------------------------------------------------
# QuantConnect (LEAN CLI) — required for Docker backtests
# https://www.quantconnect.com/account → Security → User Id + API token
# -----------------------------------------------------------------------------
QUANTCONNECT_USER_ID=
QUANTCONNECT_API_TOKEN=
QC_PROJECT_ID=
QC_REST_PAGE_SIZE=100
QC_REST_PAGE_RETRIES=5
QC_REST_PAGE_RETRY_DELAY_MS=1000

# -----------------------------------------------------------------------------
# OpenAI (V1 LLM alpha — run-alpha-cycle / meta committee)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
OPENAI_BASE_URL=https://api.openai.com/v1
REQUEST_TIMEOUT_S=30
COST_BUDGET_USD=5
MAX_PARALLEL=2

# -----------------------------------------------------------------------------
# Server / database (NestJS + SQLite)
# -----------------------------------------------------------------------------
PORT=3001
FRONTEND_URL=http://localhost:3000
DATABASE_PATH=backend/data/investment.db
TYPEORM_SYNCHRONIZE=true
TYPEORM_MIGRATIONS_RUN=false

# -----------------------------------------------------------------------------
# V1 pilot / LEAN
# -----------------------------------------------------------------------------
LEAN_CLI_PATH=
LEAN_ALLOW_SIMULATOR=false
LEAN_STRICT_CLI=true
LEAN_DOWNLOAD_DATA=false
ALLOW_PAID_QC_LOCAL_DATA_DOWNLOAD=false
ALLOW_SYNTHETIC_FEATURES=false
LIVE_PREFLIGHT_ALLOW_RESEARCH=false
V1_UNIVERSE_MANIFEST=config/universes/quality-gated-v2.json
V1_UNIVERSE_PROFILE=quality_core_backtest_safe
V1_UNIVERSE_SYMBOLS=
V1_ALLOW_LEVERAGED_ETF=false

# Required when using Stooq CSV ingestion to prepare local LEAN daily data.
# Get it from https://stooq.com/q/d/?s=smh.us&get_apikey after the captcha flow.
STOOQ_API_KEY=
MARKET_DATA_INGESTION_ENABLED=false
MARKET_DATA_INGESTION_PROVIDER=stooq

# -----------------------------------------------------------------------------
# Live / broker (keep false until verified)
# -----------------------------------------------------------------------------
BROKER_PROVIDER=toss
BROKER_WRITE_ENABLED=false
LIVE_TRADING_ENABLED=false
MAX_LIVE_PILOT_NOTIONAL_USD=10

# Toss OpenAPI read-only checks. Leave schema flags false until verified against
# real Toss responses for the configured account.
BROKER_READ_ONLY_ENABLED=false
TOSS_READ_ONLY_POLLER_ENABLED=false
TOSS_OPEN_API_BASE_URL=https://openapi.tossinvest.com
TOSS_OPEN_API_CLIENT_ID=
TOSS_OPEN_API_CLIENT_SECRET=
TOSS_OPEN_API_ACCOUNT_REF=
TOSS_OPEN_API_ACCOUNT_SEQ=
TOSS_OPEN_API_SCHEMA_VERIFIED=false
TOSS_OPEN_API_LAST_VERIFIED_AT=
TOSS_READ_ONLY_FILL_POLLER_ENABLED=false
TOSS_OPEN_API_FILL_SCHEMA_VERIFIED=false
TOSS_OPEN_API_FILLS_PATH=
TOSS_READ_ONLY_HTTP_TIMEOUT_MS=10000

# Toss live-write readiness. Production requires an external secret reference and
# verified order/cancel/flatten/open-order behavior before any real notional.
TOSS_OPEN_API_SANDBOX_VERIFIED=false
BROKER_CREDENTIAL_CUSTODY_MODE=missing
BROKER_CREDENTIAL_SECRET_REF=
TOSS_OPEN_API_SECRET_REF=
TOSS_ORDER_SCHEMA_VERIFIED=false
BROKER_CANCEL_FLATTEN_READY=false
BROKER_OPEN_ORDER_POLL_VERIFIED=false

LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Legacy report stack (optional)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
ENABLE_MIDDAY_REPORT=false
ENABLE_WEEKLY_REPORT=false
NOTIFICATION_WEBHOOK_URL=
