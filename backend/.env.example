# Copy to backend/.env OR prefer repo-root .env (see README.md § Clone on a new machine).
# V1 CLI loads repo-root .env first via backend/src/shared/repo-env.loader.ts.
# Never commit .env.

# -----------------------------------------------------------------------------
# QuantConnect (LEAN CLI)
# Request: https://www.quantconnect.com/account → Security → email with User Id + API token
# -----------------------------------------------------------------------------
QUANTCONNECT_USER_ID=your_qc_user_id
QUANTCONNECT_API_TOKEN=your_qc_api_token

# After filling: ./scripts/lean-login-from-env.sh then ./scripts/setup-lean-workspace.sh

# -----------------------------------------------------------------------------
# OpenAI (V1 LLM alpha — required for run-alpha-cycle with LLM committee)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
REQUEST_TIMEOUT_S=30
COST_BUDGET_USD=5
MAX_PARALLEL=2

# Optional override (defaults to backend/.env when unset)
LINCEI_OPENAI_ENV_FILE=

# -----------------------------------------------------------------------------
# Server / database
# -----------------------------------------------------------------------------
PORT=3001
FRONTEND_URL=http://localhost:3000
DATABASE_PATH=data/investment.db
TYPEORM_SYNCHRONIZE=true
TYPEORM_MIGRATIONS_RUN=false

# -----------------------------------------------------------------------------
# Legacy report stack (optional)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
OPENAI_API_KEY_REPORTS=

# -----------------------------------------------------------------------------
# V1 pilot / LEAN
# -----------------------------------------------------------------------------
LEAN_CLI_PATH=
LEAN_ALLOW_SIMULATOR=false
LEAN_STRICT_CLI=true
ALLOW_SYNTHETIC_FEATURES=false
LIVE_PREFLIGHT_ALLOW_RESEARCH=false

STOOQ_API_KEY=
MARKET_DATA_INGESTION_ENABLED=false
MARKET_DATA_INGESTION_PROVIDER=stooq

# -----------------------------------------------------------------------------
# Live / broker (all false until verified)
# -----------------------------------------------------------------------------
BROKER_WRITE_ENABLED=false
LIVE_TRADING_ENABLED=false
MAX_LIVE_PILOT_NOTIONAL_USD=10
BROKER_PROVIDER=toss
TOSS_ORDER_SCHEMA_VERIFIED=false
TOSS_OPEN_API_SCHEMA_VERIFIED=false
BROKER_CANCEL_FLATTEN_READY=false

LOG_LEVEL=info
