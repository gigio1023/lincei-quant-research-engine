#!/usr/bin/env bash
# Runs the current validation loop through live preflight. Exit 2 from preflight is a valid fail-closed outcome.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

export LEAN_DOWNLOAD_DATA="${LEAN_DOWNLOAD_DATA:-false}"
# Default to local benchmark data for no-download smoke. Set
# USE_QUALITY_UNIVERSE=true only when local quality-universe data already exists.
# Full quality-universe validation should use run-cloud-quality-backtest to avoid
# local QuantConnect data-download charges.
if [[ "${USE_QUALITY_UNIVERSE:-false}" != "true" ]]; then
  export V1_UNIVERSE_SYMBOLS="${V1_UNIVERSE_SYMBOLS:-SPY,QQQ,IWM}"
fi

ARG_SKIP_ALPHA_CYCLE=false
for arg in "$@"; do
  if [[ "$arg" == "--skip-alpha-cycle" ]]; then
    ARG_SKIP_ALPHA_CYCLE=true
  fi
done

./scripts/run-full-backtest.sh "$@"

if [[ "${SKIP_ALPHA_CYCLE:-false}" != "true" && "$ARG_SKIP_ALPHA_CYCLE" != "true" ]]; then
  set +e
  ./scripts/run-alpha-cycle
  ALPHA_STATUS=$?
  set -e
  if [[ "$ALPHA_STATUS" -ne 0 ]]; then
    if [[ "${REQUIRE_ALPHA_CYCLE:-false}" == "true" ]]; then
      exit "$ALPHA_STATUS"
    fi
    echo "Alpha cycle is blocked; continuing to paper/preflight so blockers are recorded." >&2
  fi
fi

set +e
./scripts/run-paper-cycle
PAPER_STATUS=$?
set -e
if [[ "$PAPER_STATUS" -eq 2 ]]; then
  echo "Paper cycle is blocked by explicit gates; continuing to live preflight so blockers are recorded." >&2
elif [[ "$PAPER_STATUS" -ne 0 ]]; then
  echo "Validation cycle failed during paper cycle (exit $PAPER_STATUS)." >&2
  exit "$PAPER_STATUS"
fi

set +e
./scripts/live-preflight
PREFLIGHT_STATUS=$?
set -e

if [[ "$PREFLIGHT_STATUS" -eq 0 ]]; then
  echo "Validation cycle complete: live preflight is ready."
elif [[ "$PREFLIGHT_STATUS" -eq 2 ]]; then
  echo "Validation cycle complete: live preflight is blocked by explicit gates."
else
  echo "Validation cycle failed during live preflight (exit $PREFLIGHT_STATUS)." >&2
  exit "$PREFLIGHT_STATUS"
fi
